name: gelato-magico

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      data: {type: str, default: "data/icecream_sales.csv"}
      experiment-name: {type: str, default: "gelato-magico-experiment"}
      model-name: {type: str, default: "gelato-magico-model"}
      test-size: {type: float, default: 0.2}
      random-state: {type: int, default: 42}
      artifact-dir: {type: str, default: "model_artifacts"}
    command: "python train.py --data {data} --experiment-name {experiment-name} --model-name {model-name} --test-size {test-size} --random-state {random-state} --artifact-dir {artifact-dir}"
  
  evaluate:
    parameters:
      model-dir: {type: str, default: "model_artifacts"}
      test-data: {type: str, default: "data/test_data.csv"}
      output-dir: {type: str, default: "evaluation_results"}
    command: "python evaluate.py --model-dir {model-dir} --test-data {test-data} --output-dir {output-dir}"
  
  predict:
    parameters:
      input: {type: str, default: "data/sample_request.json"}
    command: "python score.py --input {input}"
